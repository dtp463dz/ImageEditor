<Window x:Class="ImageEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Background="#121212"
        Title="Visionary Editor Pro" Height="1000" Width="1500">

    <Window.Resources>
        <!-- ĐỊNH NGHĨA NỀN CARO (TRANSPARENCY BACKGROUND) -->
        <VisualBrush x:Key="CheckerboardBrush" TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
            <VisualBrush.Visual>
                <Grid Width="20" Height="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="10"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="10"/>
                    </Grid.RowDefinitions>
                    <!-- Hai ô màu xám đậm -->
                    <Rectangle Grid.Row="0" Grid.Column="0" Fill="#252525"/>
                    <Rectangle Grid.Row="1" Grid.Column="1" Fill="#252525"/>
                    <!-- Hai ô màu đen xám -->
                    <Rectangle Grid.Row="0" Grid.Column="1" Fill="#1E1E1E"/>
                    <Rectangle Grid.Row="1" Grid.Column="0" Fill="#1E1E1E"/>
                </Grid>
            </VisualBrush.Visual>
        </VisualBrush>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- 1. TOP MENU BAR -->
        <Menu DockPanel.Dock="Top" Background="#1E1E1E" Foreground="White" Padding="5">
            <MenuItem Header="Tệp" Foreground="White">
                <MenuItem Header="Mở ảnh" Foreground="White" Click="MenuItem_OpenImage"/>
                <MenuItem Header="Lưu ảnh" Foreground="White" Click="MenuItem_SaveImage"/>
                <Separator/>
                <MenuItem Header="Thoát" Foreground="White" Click="MenuItem_Exit"/>
            </MenuItem>
            <MenuItem Header="Chỉnh sửa" Foreground="White">
                <MenuItem Header="Xóa ảnh" Foreground="White" Click="MenuItem_DeleteImage"/>
                <MenuItem Header="Quay về ban đầu" Foreground="White" Click="MenuItem_ResetImage"/>
                <Separator/>
                <MenuItem Header="Cắt (Px)" Foreground="White" Click="MenuItem_CropImage"/>
                <MenuItem Header="Cắt (%)" Foreground="White" Click="MenuItem_CropPercentImage"/>
                <Separator/>
                <MenuItem Header="Độ sáng" Click="MenuItem_ShowBrightnessPanel"/>
                <MenuItem Header="Màu ảnh" Click="MenuItem_ShowColorPanel"/>
                <MenuItem Header="Reset" Click="MenuItem_ResetAdjustments"/>
            </MenuItem>
            <MenuItem Header="Hình ảnh" Foreground="White">
                <MenuItem Header="Lật dọc" Click="MenuItem_FlopHorizontalImage"/>
                <Separator/>
                <MenuItem Header="Lật ngang" Click="MenuItem_FlopVerticalImage"/>
            </MenuItem>
            <MenuItem Header="Lớp" Foreground="White"/>
            <MenuItem Header="Chọn" Foreground="White"/>
            <MenuItem Header="Di chuyển" Foreground="White"/>
            <MenuItem Header="Bộ lọc" Foreground="White"/>
            <MenuItem Header="Xem" Foreground="White"/>
            <MenuItem Header="Hỗ trợ" Foreground="White"/>
        </Menu>

        <!-- 2. SUB-TOP TOOL PROPERTIES -->
        <Border DockPanel.Dock="Top" Background="#252525" Height="70" BorderBrush="#121212" BorderThickness="0,1,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <Button Name="BtnOpenImage"
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="White" Height="35" Padding="15,0"
                        Click="BtnOpenImage_Click">
                    
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="FolderOpen" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Mở ảnh" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Name="BtnDeleteImage"
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="White" Height="35" Margin="10,0" 
                        Click="BtnDeleteImage_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Delete" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Xóa ảnh" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Name="BtnCropImage"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White" Height="35" Padding="15,0"
                        Click="BtnCropImage_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Crop" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Cắt ảnh" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Name="BtnRotate90"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White" Height="35" Padding="15,0"
                        Click="BtnRotate90_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="RotateRight" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Xoay 90°" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Name="BtnRotate180"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White" Height="35" Padding="15,0"
                        Click="BtnRotate180_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="RotateRight" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Xoay 180°" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Name="BtnRotate270"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White" Height="35" Padding="15,0"
                        Click="BtnRotate270_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="RotateLeft" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Xoay 270°" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Name="BtnReset"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White" Height="35" Padding="15,0"
                        Click="BtnReset_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Undo" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Quay lại" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Name="BtnSaveImage"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White"
                        Height="35"
                        Padding="15,0" Click="BtnSaveImage_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Download" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Lưu ảnh" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Margin="10,8" Background="#444444"/>
                <Button Name="BtnBrightness"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White" Height="35"
                        Padding="15,0"
                        Click="BtnBrightness_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Brightness6" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Sáng tối" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Name="BtnColorMix"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White"
                        Height="35" Padding="15,0"
                        Click="BtnColorMix_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Palette" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Màu sắc" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Name="BtnResetAdj"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White"
                        Height="35" Padding="15,0"
                        Click="BtnResetAdj_Click">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="RefreshCircle" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Quay lại" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- 3. LEFT TOOLBAR -->
        <Border DockPanel.Dock="Left" Width="50" Background="#1E1E1E" BorderBrush="#121212" BorderThickness="0,0,1,0">
            <Grid>
                <StackPanel Margin="0,10">
                    <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Select Tool" Foreground="White">
                        <md:PackIcon Kind="CursorDefaultOutline" />
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Crop Tool" Foreground="#AAAAAA">
                        <md:PackIcon Kind="Crop" />
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Magic Wand" Foreground="#AAAAAA">
                        <md:PackIcon Kind="AutoFix" />
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Brush" Foreground="#AAAAAA">
                        <md:PackIcon Kind="Brush" />
                    </Button>
                </StackPanel>

                <!-- Color Swatch at Bottom -->
                <StackPanel VerticalAlignment="Bottom" Margin="0,20" HorizontalAlignment="Center">
                    <Grid Width="30" Height="30">
                        <Border Background="White" Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" CornerRadius="2" BorderBrush="Black" BorderThickness="1"/>
                        <Border Background="Black" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Bottom" CornerRadius="2" BorderBrush="Gray" BorderThickness="1"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 4. RIGHT SIDE PANELS -->
        <Border DockPanel.Dock="Right" Width="320" Background="#1E1E1E" BorderBrush="#121212" BorderThickness="1,0,0,0">
            <TabControl Name="MainTabControl" Background="#1E1E1E" Foreground="White">
                <TabItem Header="Layers" Background="#252525" Foreground="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="250"/>
                        </Grid.RowDefinitions>

                        <!-- Layer Section -->
                        <Expander Header="Layers" IsExpanded="True" Grid.Row="0" Foreground="White" md:ExpanderAssist.HeaderBackground="#252525">
                            <Grid>
                                <ListBox Background="Transparent" BorderThickness="0"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="5">
                                    <Button Style="{StaticResource MaterialDesignIconButton}" Width="30" Height="30">
                                        <md:PackIcon Kind="Plus" Foreground="Gray"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" Width="30" Height="30">
                                        <md:PackIcon Kind="DeleteOutline" Foreground="Gray"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Expander>

                        <!-- History Section -->
                        <Expander Header="Lịch sử" IsExpanded="True" Grid.Row="1" Foreground="White" md:ExpanderAssist.HeaderBackground="#252525">
                            <ListBox Background="Transparent" BorderThickness="0">
                                <ListBoxItem Background="#00897B" Foreground="White">
                                    <DockPanel LastChildFill="True">
                                        <md:PackIcon Kind="FileImageOutline" VerticalAlignment="Center"/>
                                        <TextBlock Text="Mở ảnh" Margin="10,0" VerticalAlignment="Center"/>
                                        <md:PackIcon Kind="DeleteOutline" HorizontalAlignment="Right"/>
                                    </DockPanel>
                                </ListBoxItem>
                            </ListBox>
                        </Expander>
                    </Grid>
                </TabItem>

                <TabItem Header="Sáng tối" Background="#252525" Name="TabBrightness" Foreground="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <TextBlock Text="Sáng Tối" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <!--Sang toi-->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Độ sáng: " Foreground="White" Width="80"/>
                                    <TextBlock Name="BrightnessValue" Text="0%" Foreground="#00897B" TextAlignment="Right" Width="60"/>
                                </StackPanel>
                                <Slider Name="SliderBrightness"
                                        Minimum="-100" Maximum="100" Value="0"
                                        Background="#252525" Foreground="#00897B"
                                        PreviewMouseLeftButtonDown="SliderBrightness_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="SliderBrightness_PreviewMouseLeftButtonUp"
                                        PreviewMouseMove="SliderBrightness_PreviewMouseMove"/>
                                <TextBlock Text="Tối ← → Sáng" Foreground="#888888" FontSize="11" TextAlignment="Center"/>
                            </StackPanel>
                            <Separator Background="#333333"/>
                            <!--tuong phan-->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Độ tương phản: " Foreground="White" Width="80"/>
                                    <TextBlock Name="ContrastValue" Text="0%" Foreground="#00897B" TextAlignment="Right" Width="60"/>
                                </StackPanel>
                                <Slider Name="SliderContrast"
                                        Minimum="-100" Maximum="100" Value="0"
                                        PreviewMouseLeftButtonDown="SliderContrast_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="SliderContrast_PreviewMouseLeftButtonUp"
                                        PreviewMouseMove="SliderContrast_PreviewMouseMove"
                                        Background="#252525" Foreground="#00897B"/>
                                <TextBlock Text="Mềm ← → Sắc nét" Foreground="#888888" FontSize="11" TextAlignment="Center"/>
                            </StackPanel>
                            <Separator Background="#333333"/>

                            <!--bao hoa-->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Bão hòa: " Foreground="White" Width="80"/>
                                    <TextBlock Name="SaturationValue" Text="0%" Foreground="#00897B" TextAlignment="Right" Width="60"/>
                                </StackPanel>
                                <Slider Name="SliderSaturation"
                                        Minimum="-100" Maximum="100" Value="0"
                                        PreviewMouseLeftButtonDown="SliderSaturation_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="SliderSaturation_PreviewMouseLeftButtonUp"
                                        PreviewMouseMove="SliderSaturation_PreviewMouseMove"
                                        Background="#252525" Foreground="#00897B"/>
                                <TextBlock Text="Trắng đen ← → Rực rỡ" Foreground="#888888" FontSize="11" TextAlignment="Center"/>
                            </StackPanel>

                            <!--Button apply-->
                            <Button Name="BtnApplyBrightness"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="White"
                                    Background="#00897B"
                                    Click="BtnApplyBrightness_Click">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Check" Margin="0,0,5,0"/>
                                    <TextBlock Text="Áp dụng"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!--Item màu sắc-->
                <TabItem Header="Màu sắc" Background="#252525" Name="TabColorMix" Foreground="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <TextBlock Text="Color Mix - Trộn màu" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            <!--Red-->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Fill="Red" Width="20" Height="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="Đỏ: " Foreground="White" Width="60"/>
                                    <TextBlock Name="RedValue" Text="0%" Foreground="#FF6B6B" TextAlignment="Right" Width="60"/>
                                </StackPanel>
                                <Slider Name="SliderRed"
                                        Minimum="-100" Maximum="100" Value="0"
                                        PreviewMouseLeftButtonDown="SliderRed_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="SliderRed_PreviewMouseLeftButtonUp"
                                        PreviewMouseMove="SliderRed_PreviewMouseMove"
                                        Background="#252525" Foreground="#FF6B6B"
                                        />
                            </StackPanel>
                            <!--Green-->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Fill="Lime" Width="20" Height="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="Xanh lá: " Foreground="White" Width="60"/>
                                    <TextBlock Name="GreenValue" Text="0%" Foreground="#51CF66" TextAlignment="Right" Width="60"/>
                                </StackPanel>
                                <Slider Name="SliderGreen"
                                        Minimum="-100" Maximum="100" Value="0"
                                        PreviewMouseLeftButtonDown="SliderGreen_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="SliderGreen_PreviewMouseLeftButtonUp"
                                        PreviewMouseMove="SliderGreen_PreviewMouseMove"
                                        Background="#252525" Foreground="#51CF66"
                                        />
                            </StackPanel>
                               <!--Blue-->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Fill="Blue" Width="20" Height="20" Margin="0,0,10,0"/>
                                    <TextBlock Text="Xanh dương: " Foreground="White" Width="60"/>
                                    <TextBlock Name="BlueValue" Text="0%" Foreground="#4DABF7" TextAlignment="Right" Width="60"/>
                                </StackPanel>
                                <Slider Name="SliderBlue"
                                        Minimum="-100" Maximum="100" Value="0"
                                        PreviewMouseLeftButtonDown="SliderBlue_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="SliderBlue_PreviewMouseLeftButtonUp"
                                        PreviewMouseMove="SliderBlue_PreviewMouseMove"
                                        Background="#252525" Foreground="#4DABF7"
                                        />
                            </StackPanel>
                            
                            <Separator Background="#333333"/>
                            <!--Xoay sắc độ-->
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Palette" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Tông màu: " Foreground="White" Width="60"/>
                                    <TextBlock Name="HueValue" Text="0%" Foreground="#00897B" TextAlignment="Right" Width="60"/>
                                </StackPanel>
                                <Slider Name="SliderHue"
                                        Minimum="-180" Maximum="180" Value="0"
                                        PreviewMouseLeftButtonDown="SliderHue_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="SliderHue_PreviewMouseLeftButtonUp"
                                        PreviewMouseMove="SliderHue_PreviewMouseMove"
                                        Background="#252525" Foreground="#4DABF7"
                                        />
                            </StackPanel>
                            
                            <Separator Background="#333333"/>
                            <!--Preview color-->
                            <TextBlock Text="Xem trước màu: " Foreground="White" FontSize="12"/>
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Name="PreviewColor" Fill="#808080" Width="100" Height="60" RadiusX="5" RadiusY="5"/>
                                <TextBlock Name="PreviewHex" Text="#808080" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                            </StackPanel>

                            <Button Name="BtnApplyColor"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="White"
                                    Background="#00897B"
                                    Click="BtnApplyColor_Click">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Check" Margin="0,0,5,0"/>
                                    <TextBlock Text="Áp dụng"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <!-- 5. MAIN CANVAS AREA -->
        <Grid Background="#121212">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#121212">
                <Grid Margin="100">
                    <!-- Shadow giả cho Canvas -->
                    <Border Background="Black" Opacity="0.3" Margin="5,5,-5,-5" Width="800" Height="600"/>

                    <!-- Nền caro và Ảnh chính -->
                    <Border Background="{StaticResource CheckerboardBrush}" Width="800" Height="600" BorderBrush="#333" BorderThickness="1">
                        <Image Source="{Binding DisplayImageSource}" 
                               RenderOptions.BitmapScalingMode="NearestNeighbor">
                            <Image.LayoutTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Image.LayoutTransform>
                        </Image>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- Status Bar Information -->
            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="15" Orientation="Horizontal">
                <Border Background="#1E1E1E" Padding="5,2" CornerRadius="2">
                    <TextBlock Name="StatusText" Text="Chưa tải ảnh" Foreground="#888888" FontSize="11"/>
                </Border>
            </StackPanel>

            <!-- Save/Download FAB -->
            <Button Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20"
                    Background="#00897B" BorderBrush="Transparent">
                <md:PackIcon Kind="Download" Foreground="White"/>
            </Button>
        </Grid>
    </DockPanel>
</Window>